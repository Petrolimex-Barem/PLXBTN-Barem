}

function ajPageAsynch(url, params) {
    return new Promise((resolve, reject) => {
        var http = new XMLHttpRequest();
        http.open('POST', url, true);
        http.setRequestHeader('Content-type', 'application/x-www-form-urlencoded');
        http.onreadystatechange = function () {
            if (http.readyState == 4) {
                if (http.status == 200) {
                    resolve(http.responseText);
                } else {
                    reject(http.status);
                }
            }
        };
        http.send(params);
    });
}

function ajPage(e, g, h, d) {
    var b = null;
    try {
        b = new ActiveXObject("Microsoft.XMLHTTP")
    } catch (f) {
        b = new XMLHttpRequest()
    }
    b.open("POST", e, d ? false : true);
    b.onreadystatechange = function() {
        if (b.readyState != 4) {
            return
        } else {
            if (b.status == 0 || b.status == 12029) {
                alert("No network connection (" + b.status + ")");
                return
            } else {
                if (b.status == 404) {
                    alert(e + " is not found on the Server");
                    return
                } else {
                    if (b.status != 200) {
                        if (confirm(e + " failed (status=" + b.status + ")!\nClick OK to view details!")) {
                            document.write(b.responseText);
                            document.close()
                        }
                        return
                    } else {
                        if (b.responseText.substring(0, 12) == "<!--ERROR-->") {
                            document.write(b.responseText);
                            return
                        }
                    }
                }
            }
        }
        g(b);
        b = null
    };
    if (h) {
        b.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
        b.setRequestHeader("Content-length", h.length);
        b.send(h)
    } else {
        b.send(null)
    }
}

function ajFrmSubmit(d, g, f, k, b) {
    if (!k) {
        var k = ""
    }
    if (k == "") {
        k = "ajfrmsmt_=1"
    }
    var n, h;
    for (var e = 0; e < g.length; e++) {
        n = g.elements[e];
        switch (n.type) {
            case "checkbox":
            case "radio":
                if (n.checked) {
                    h = n.value
                } else {
                    h = ""
                }
                break;
            default:
                h = n.value
        }
        k += "&" + n.name + "=" + h
    }
    ajPage(d, f, k, b)
}

function detectbrowser() {
    var e = -1;
    if (navigator.appName == "Microsoft Internet Explorer") {
        var b = navigator.userAgent;
        var d = new RegExp("MSIE ([0-9]{1,}[.0-9]{0,})");
        if (d.exec(b) != null) {
            e = parseFloat(RegExp.$1)
        }
    }
    return e
}

function detectie6() {
    var b = detectbrowser();
    if (b == -1 || b > 6) {
        return false
    } else {
        return true
    }
}

function ie6fixifrm(f, g, e) {
    var d;
    if (document.getElementById(g)) {
        d = document.getElementById(g)
    } else {
        d = document.createElement("iframe");
        d.id = g;
        document.body.appendChild(d)
    }
    d.frameBorder = 0;
    d.style.position = "absolute";
    if (f) {
        d.style.left = f.offsetLeft;
        d.style.top = f.offsetTop;
        d.style.width = f.offsetWidth;
        if (e) {
            d.style.width = f.offsetWidth - e
        }
        d.style.height = f.offsetHeight;
        f.style.zIndex += 1
    } else {
        d.style.height = "1px"
    }
}

