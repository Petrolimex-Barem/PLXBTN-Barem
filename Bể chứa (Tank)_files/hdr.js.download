function increaseMenuFrequency(menuId, menuName) {
    const currentUserId = document.getElementById("uidHolder").value;
    const key = "menuFrequency_" + currentUserId;
    let freq = JSON.parse(localStorage.getItem(key) || "{}");

    if (!freq[menuId]) {
        freq[menuId] = { name: menuName, count: 0, id: "" };
    }

    freq[menuId].count++;
    localStorage.setItem(key, JSON.stringify(freq));
}

document.addEventListener("click", function (e) {
    const t = e.target;
    if (t.classList.contains("dnMnuLink")) {
        e.preventDefault();
        const menuId = t.getAttribute("href");
        const menuName = t.dataset.menuname;
        const target = t.getAttribute("target");

        increaseMenuFrequency(menuId, menuName);
        if (target && target !== "_self") {
            window.open(menuId, target);
        } else {
            window.location.href = menuId;
        }
        return;
    }
});