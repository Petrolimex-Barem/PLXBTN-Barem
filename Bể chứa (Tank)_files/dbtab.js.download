    try {
        var firstSelect;
		if(document.DBtabform.cell02)
		{
			var firstSelect = document.DBtabform.cell02;
			var hasBDFirst = firstSelect && firstSelect.value == "1";
			if (firstSelect.name == e) {
				inputFieldsStr = '<option value="1">Bắt đầu hoạt động</option>';
			}
			if (e != firstSelect.name) {
				inputFieldsStr = '<option value="2">Hoạt động</option><option value="3">Dừng</option>';
			}
		}
    } catch (ex) {
        inputFieldsStr = "";
    }
    return inputFieldsStr;
}
function fillOptions(e, c, b, g) {
    if (document.DBtabform && document.DBtabform.tabindex && document.DBtabform.tabindex.value == "POS_INFO" && c == 3) {
        var inputFieldsStr = handleBanQuyen(e);
        if (inputFieldsStr != "") {
            inputFields[c - 1] = inputFieldsStr;
        }
    }
    var a = document.getElementById("td_" + e);
    var h = 'value="' + g + '">';
    var d = 'value="' + g + '" selected>';
    var f = (inputFields[c - 1].replace(" selected", "")).replace(h, d);
    a.innerHTML = "<select name='" + e + "' onChange='markRowChange(" + b + ")'>" + f + "</select>"
}

function showhelp(c, b) {
    var a = document.getElementById("helpdisp");
    if (a.style.display == "none") {
        ajPage("BasetabText.aspx?id=" + c + "&stage=" + b, showhelpret)
    } else {
        a.style.display = "none"
    }
}

function showhelpret(b) {
    var a = document.getElementById("helpdisp");
    a.style.display = "inline";
    a.innerHTML = b.responseText
}

function pastehandle(c, d, b) {
    c.style.display = "none";
    var a = c.innerHTML;
    if (d && d.clipboardData && d.clipboardData.getData) {
        if (/text\/html/.test(d.clipboardData.types)) {
            c.innerHTML = d.clipboardData.getData("text/html")
        } else {
            if (/text\/plain/.test(d.clipboardData.types)) {
                c.innerHTML = d.clipboardData.getData("text/plain")
            } else {
                c.innerHTML = ""
            }
        }
        pastewait(c, a, b);
        if (d.preventDefault) {
            d.stopPropagation();
            d.preventDefault()
        }
        return false
    } else {
        c.innerHTML = "";
        pastewait(c, a, b);
        return true
    }
}

function pastewait(c, a, b) {
    if (c.childNodes && c.childNodes.length > 0) {
        pasteprocess(c, a, b)
    } else {
        that = {
            e: c,
            s: a
        };
        that.callself = function() {
            pastewait(that.e, that.s, b)
        };
        setTimeout(that.callself, 20)
    }
}

function pasteprocess(c, b, l) {
    var k = ",.,J,>,I,N,P,D,O,T,";
    try {
        var f = c.getElementsByTagName("table")[0];
        var a = f.rows.length;
        if (a > 500) {
            a = 500
        }
        var g, e, m, d;
        for (g = a - 1; g >= 0; g--) {
            insertTabRow("dbtablist");
            m = f.rows[g];
            d = m.cells.length;
            if (d > tab_m) {
                d = tab_m
            }
            for (e = 0; e < d; e++) {
                let elm = document.DBtabform.elements["cell" + (tab_n - 1) + convi10(e)];
                let exVal = elmText(m.cells[e]);

                if (k.indexOf("," + inputTypes[e] + ",") >= 0) {
                    elm.value = exVal;
                }
                else if (inputTypes[e] == '!') {
                    elm.checked = (exVal != '')
                }
                else if ((inputTypes[e] == '~' || inputTypes[e] == '&') && elm.type == 'select-one') {
                    if (checkTextInAnyOptionValue(elm, exVal)) {
                        elm.value = exVal;
                    }

                    let idx = checkTextInAnyOptionText(elm, exVal);
                    if (idx != -1) {
                        elm.options[idx].selected = true;
                    }
                }                
            }
        }
    } catch (h) {
        alert("Wrong format pasted (IE: links might be problem. Refresh this page!)")
    }
    c.style.display = "inline";
    c.innerHTML = b
};

function checkTextInAnyOptionValue(selectElement, searchText) {
    const options = selectElement.options;
    for (let i = 0; i < options.length; i++) {
        const option = options[i];
        if (option.value.includes(searchText)) {
            return true;
        }
    }
    return false;
}

function checkTextInAnyOptionText(selectElement, searchText) {
    const options = selectElement.options;
    for (let i = 0; i < options.length; i++) {
        const option = options[i];
        if (option.text.startsWith(searchText)) {
            return i;
        }
    }
    return -1;
}

function basetabcell(row, col) {
    const frm = document.DBtabform;
    return frm.elements[`cell${row}${col > 9 ? '_' + col : col}`];
}

function basetabfunc(el, func, params, sync) {
    const frm = document.DBtabform;
    const name = el.name.replace('cell', '');
    const [row, col] = name.includes('_') ? name.split('_') : [name.slice(0, -1), name.slice(-1)];

    let inputCols = [], targetCol = '';
    if (params?.includes('=>')) {
        [inputCols, targetCol] = params.split('=>').map(p => p.trim());
        inputCols = inputCols.split('||');
    } else {
        inputCols = params ? params.split('||') : [col];
        targetCol = col;
    }

    const vals = inputCols.map(c => {
        let v = basetabcell(row, c)?.value || 0;
        return (isNumeric(v) || isNumericNeg(v)) ? removeSepr(v) : 0;
    }).join(';');

    const q = `dbtab=${frm.tabindex.value}&row=${row}&col=${col}&targetcol=${targetCol}&params=${params}&vals=${vals}`;
    ajPage(`${func}.aspx`, r => eval(r.responseText), q, sync);
}

function iifarr(arr, index) {
    return (Array.isArray(arr) && arr[index] !== undefined) ? arr[index] : "";
}
function validatePOSInfoForm() {
    var f = document.DBtabform;
    if (!f || !f.tabindex || f.tabindex.value !== "POS_INFO") return true;

    var table = document.getElementById("dbtablist");
    if (!table) return true;

    var allRows = table.querySelectorAll(
        ":scope > thead > tr, :scope > tbody > tr"
    );
    var rows = [];
    for (var i = 0; i < allRows.length; i++) {
        var tr = allRows[i];

        var directInputs = tr.querySelectorAll(
            ":scope > td input[name^='cell']"
        );

        if (directInputs.length > 0) {
            rows.push(tr);
        }
    }

    if (rows.length === 0) return true;

    var ordered = [];

    for (var i = 0; i < rows.length; i++) {
        if (rows[i].querySelector(":scope > td input[name^='I']")) {
            ordered.push(rows[i]);
        }
    }
    for (var i = 0; i < rows.length; i++) {
        if (!rows[i].querySelector(":scope > td input[name^='I']")) {
            ordered.push(rows[i]);
        }
    }

    // Các cột cần kiểm tra
    var cols = [
        { idx: 3, label: "Phần mềm" },
        { idx: 4, label: "Cột bơm" },
        { idx: 5, label: "Đo bể" },
        { idx: 6, label: "Tủ AGAS Controller" },
        { idx: 7, label: "POS" }
    ];

    clearHighlight(table);

    var prev = {};

    for (var r = 0; r < ordered.length; r++) {
        var tr = ordered[r];
        var hasDate = false;

        for (var c = 0; c < cols.length; c++) {
            var col = cols[c];
            var input = tr.querySelector(":scope > td input[name^='cell'][name$='" + col.idx + "']");
            if (!input) continue;

            var val = input.value.trim();
            if (!val) continue;

            hasDate = true;

            if (prev[col.idx] && !isDateGreater(val, prev[col.idx])) {
                highlight(input);
                alert(
                    'Ngày bắt đầu tại cột "' + col.label +
                    '" của dòng ' + (r + 1) +
                    ' phải lớn hơn dòng trước'
                );
                input.focus();
                return false;
            }

            prev[col.idx] = val;
        }

        if (!hasDate) {
            highlight(tr);
            alert(
                "Dòng " + (r + 1) +
                " phải nhập ngày bắt đầu của ít nhất 1 loại bản quyền"
            );
            return false;
        }
    }

    return true;
}
function highlight(el) {
    el.style.border = "2px solid red";
    el.style.backgroundColor = "#ffecec";
}

function clearHighlight(table) {
    var inputs = table.querySelectorAll("input[name^='cell']");
    for (var i = 0; i < inputs.length; i++) {
        inputs[i].style.border = "";
        inputs[i].style.backgroundColor = "";
    }
}
function isDateGreater(d1, d2) {
    var p1 = d1.split("/");
    var p2 = d2.split("/");

    var t1 = new Date(p1[2], p1[1] - 1, p1[0]).getTime();
    var t2 = new Date(p2[2], p2[1] - 1, p2[0]).getTime();

    return t1 > t2;
}