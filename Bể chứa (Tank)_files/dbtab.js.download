function dbtabkeyhandle(a) {
    var c = evobj(a);
    if (c.ctrlKey && ekeyCode(c) == 83) {
        var b = document.DBtabform;
        if (document.getElementById("savebtn") != null) {
            cancel_bubble(c);
            submitForm(b)
        }
    } else {
        escPage(c)
    }
}

function dbtabkeyhandle1(a) {
    var c = evobj(a);
    if (c.ctrlKey && ekeyCode(c) == 83) {
        if (!SysAdminOnly) {
            cancel_bubble(c);
            var b = setTimeout("mySubmit()", 100)
        }
    } else {
        escPage(c)
    }
}

function submitForm(a) {
    document.getElementById("savebtn").focus();
    a.rows.value = tab_n;
    a.cmd.value = "";
    a.submit()
}

function delDBRow() {
    if (SysAdminOnly) {
        alert("Disabled!")
    } else {
        var a = document.DBtabform;
        if (confirm("Delete selected rows?")) {
            a.action = "saveDBTable.aspx";
            a.cmd.value = "del";
            a.submit()
        } else {
            return false
        }
    }
}

function delDBRowWithReason() {
    if (SysAdminOnly) {
        alert("Disabled!");
        return;
    }

    var a = document.DBtabform;
    var reason = "";

    while (true) {
        reason = prompt("Nhập lý do xóa:");

        if (reason === null) {
            // Nhấn Cancel
            return false;
        }

        reason = reason.trim();

        if (reason === "") {
            alert("Cần nhập lý do.");
            continue; // quay lại prompt
        }

        if (reason.length > 450) {
            alert("Tối đa 450 ký tự.");
            continue; // quay lại prompt
        }

        if (confirm("Delete selected rows?")) {
            a.action = "saveDBTable.aspx";
            a.cmd.value = "del";
            a.reason.value = reason;
            a.submit()
        } else {
            return false
        }
        break; // thoát vòng lặp
    }
}

function convi10(a) {
    return a < 10 ? a : "_" + a
}

function insertTabRow(tab, loadeds) {
    var FK, dm, dc, i, k, isize, cellc, inputname, inputpart, radioval, radiotext, idefault, elm;
    var inputdef = document.bosfrm.inputDef?.value || '';
    var inputdefArr = inputdef.split("^")
    var celladded = false;
    dm = document.getElementById(tab).insertRow(1);
    dc = dm.insertCell(-1);
    dc.innerHTML = "<input type='hidden' name='Changed" + tab_n + "' value=1>";
    for (i = 0; i < tab_m; i++) {
        var syntaxStr = [];
        if(inputdefArr.length > i){
            syntaxStr = inputdefArr[i].split(",>");
        }
        idefault = (loadeds ? loadeds[i] : inputDefaults[i]);
        if (inputTypes[i] != "$") {
            dc = dm.insertCell(-1)
        }
        FK = -1;
        for (k = 0; k < FKs.length; k++) {
            if (i == FKs[k]) {
                FK = k;
                break
            }
        }
        celladded = false;
        inputname = "'cell" + tab_n + convi10(i) + "'";
        if (FK != -1 && FKVals[FK] != "") {
            idefault = (inputTypes[i] == "J" ? FKNames[FK] : FKVals[FK]);
            cellc = "<input type='hidden' name=" + inputname + " value='" + idefault + "'>";
            if (inputTypes[i] != "$") {
                cellc += FKNames[FK]
            } else {
                elm = document.createElement("input");
                elm.type = "hidden";
                elm.name = "cell" + tab_n + convi10(i);
                elm.value = idefault;
                document.DBtabform.appendChild(elm);
                celladded = true
            }
        } else {
            inputpart = " name=" + inputname + " onkeydown='focusdownitem(event, " + tab_n + "," + (i + 1) + ", -1)'";
            switch (inputTypes[i]) {
                case "~":
                case "&":
                case "ID":
                    if (document.DBtabform) {
                        if (document.DBtabform.tabindex.value == "POS_INFO" && i == 2) {
                            if (tab_n == 0) {
                                inputFields[i] = '<option value="1">Bắt đầu hoạt động</option>';
                            } else {
                                inputFields[i] = '<option value="2">Hoạt động</option><option value="3">Dừng</option>';
                            }
                        }
                    }
                    cellc = "<select" + inputpart + ">" + inputFields[i] + "</select>";
                    break;
                case "!":
                    cellc = "<input type='checkbox'" + inputpart + " value='1'" + (idefault != "" ? " checked" : "") + ">";
                    break;
                case ":":
                    radioval = inputSizes[i].split("||");
                    radiotext = inputFields[i].split("||");
                    cellc = "";
                    for (j = 0; j < radioval.length; j++) {
                        cellc += "<input type='radio'" + inputpart + " value='" + radioval[j] + "'" + (radioval[j] == idefault ? "checked" : "") + ">" + radiotext[j] + " "
                    }
                    break;
                case "$":
                    elm = document.createElement("input");
                    elm.type = "hidden";
                    elm.name = "cell" + tab_n + convi10(i);
                    elm.value = idefault;
                    document.DBtabform.appendChild(elm);
                    celladded = true;
                    break;
                case "EXC":
                    celladded = true;
                    break;
                default:
                    switch (inputTypes[i]) {
                        case "D":
                            isize = 9;
                            break;
                        case "I":
                            isize = 8;
                            break;
                        case "N":
                            isize = 16;
                            break;
                        case "P":
                            isize = 4;
                            break;
                        case "T":
                            isize = 4;
                            break;
                        case ".":
                        case "*":
                        case "J":
                            isize = inputSizes[i];
                            break;
                        default:
                            isize = 24
                    }
                    cellc = "<input" + inputpart + " size=" + isize + " maxlength=" + (isize + 1) + " value='" + idefault + "'";
                    switch (inputTypes[i]) {
                        case "D":
                            cellc += " onBlur='this.value=dateprompt(this);'><img src='../img/browse.gif' class='imggo' onClick=\"DoCal(document.DBtabform.elements[" + inputname + ']);">';
                            break;
                        case "O":
                            cellc += " onBlur='this.value=dateprompt(this, true);'><img src='../img/browse.gif' class='imggo' onClick=\"DoCal(document.DBtabform.elements[" + inputname + '], null, null, 1);">';
                            break;
                        case "I":
                        case "N":
                            cellc += " style='text-align:right' onChange=\"this.value=insertSepr(this.value);"
                            if (iifarr(syntaxStr, 6) !== "") {
                                cellc += `basetabfunc(this, '${iifarr(syntaxStr, 6)}'`;
                                
                                if (iifarr(syntaxStr, 7) !== "") {
                                    cellc += `, '${iifarr(syntaxStr, 7)}', true)`;
                                } else {
                                    cellc += ', true)';
                                }
                            }                           
                            else if (iifarr(syntaxStr, 9) !== "") {
                                cellc += iifarr(syntaxStr, 9);
                            }
                            cellc += "\">";
                            break;
                        case "J":
                            cellc += " autocomplete='off'>";
                            dc.innerHTML = cellc;
                            new actb(eval("document.DBtabform.elements[" + inputname + "]"), eval("actb" + actbnames[i] + "_text"), "setfocusdownitem(" + tab_n + "," + (i + 1) + ", -1);cancel_bubble(evobj(event));");
                            celladded = true;
                            break;
                        default:
                            cellc += ">"
                    }
            }
        }
        if (!celladded) {
            dc.innerHTML = cellc
        }
    }
    dc = dm.insertCell(-1);
    dc.innerHTML = "&nbsp;";
    tab_n += 1;
    if (parent) {
        if (parent.iframesize) {
            try {
                parent.iframesizeY()
            } catch (ex) {}
        }
    }
}

