}

function delonclick(a) {
	if (a == 0 && document.DBtabform && document.DBtabform.tabindex && document.DBtabform.tabindex.value == "POS_INFO" && document.DBtabform.cell02 && document.DBtabform.cell02.value == 1) {
        try {
            var d = document.DBtabform.recIDs[a] || document.DBtabform.recIDs;
