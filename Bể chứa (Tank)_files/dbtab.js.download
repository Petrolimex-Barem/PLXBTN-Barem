    }
}

function focusdownitem(f, a, b, g) {
    function d(e, l) {
        var h = document.DBtabform.elements["cell" + e + convi10(l)];
        if (h != null) {
            h.focus()
        }
    }

    function c(e, n) {
        var l;
        var h = document.DBtabform.elements;
        if (h["I" + e] != null) {
            l = h["cell0" + convi10(n)]
        } else {
            l = h["cell" + e + convi10(n)]
        }
        if (l != null && l.type != "hidden") {
            try {
                l.focus()
            } catch (m) {}
        }
    }
    if (!f) {
        var f = window.event
    }
    switch (ekeyCode(f)) {
        case 13:
            if (!f.shiftKey) {
                setfocusdownitem(a, b, g)
            }
            break;
        case 40:
            if (inputTypes[b - 1] != "J") {
                if (g == -1) {
                    c((a - 1), (b - 1))
                } else {
                    d((a + 1), (b - 1))
                }
            }
            break;
        case 38:
            if (inputTypes[b - 1] != "J") {
                if (g == -1) {
                    c((a + 1), (b - 1))
                } else {
                    d((a - 1), (b - 1))
                }
            }
            break
    }
}

function setfocusdownitem(a, e, f) {
    var c;
    var b = document.DBtabform.elements;
    c = b["cell" + a + convi10(e)];
    if (c) {
        if (c.type != "hidden") {
            try {
                c.focus()
            } catch (d) {}
        } else {
            setfocusdownitem(a, (e + 1), f)
        }
    } else {
        if (f == -1 && b["I" + (a + f)]) {
            c = b.cell01;
            if (c) {
                if (c.type != "hidden") {
                    c.focus()
                } else {
                    setfocusdownitem(0, 2, 1)
                }
            }
        } else {
            c = b["cell" + (a + f) + "1"];
            if (c) {
                if (c.type != "hidden") {
                    c.focus()
                } else {
                    setfocusdownitem((a + f), 2, f)
                }
            }
        }
    }
}
