}

function setCookie(d, e) {
    var b = new Date();
    b.setDate(b.getDate() + 180);
    document.cookie = d + "=" + e + ";expires=" + b.toUTCString() + ";path=/"
}

function readCookie(f) {
    var g = "";
    var b = document.cookie;
    if (b == null || b == "") {
        return ""
    } else {
        var e = b.split(f + "=")[1];
        if (e != null) {
            var d = e.split(";")[0];
            if (d != null) {
                g = unescape(d)
            }
        }
    }
    return g
}

function elmTop(b) {
    var d = 0;
    while (b) {
        d += b.offsetTop;
        b = b.offsetParent
    }
    return d
}

function elmLeft(b) {
    var d = 0;
    while (b) {
        d += b.offsetLeft;
        b = b.offsetParent
    }
    return d
}
var integerExpr = null;
var numericExpr = null;
var numericNegExpr = null;
var vietDateExpr = null;
var vietTimeExpr = null;
var vietDateTimeExpr = null;
var emailExpr = null;

function isInteger(b) {
    if (integerExpr == null) {
        integerExpr = new RegExp("^[0-9]+( [0-9]+( [0-9]+( [0-9]+)?)?)?$")
    }
    if (b.match(integerExpr)) {
        return true
    } else {
        return false
    }
}

function isNumeric(b) {
    if (numericExpr == null) {
        numericExpr = new RegExp("^[0-9]+( [0-9]+( [0-9]+( [0-9]+)?)?)?([.][0-9]+)?$")
    }
    if (b.match(numericExpr)) {
        return true
    } else {
        return false
    }
}

function isNumericNeg(b) {
    if (numericNegExpr == null) {
        numericNegExpr = new RegExp("^(-)?[0-9]+( [0-9]+( [0-9]+( [0-9]+)?)?)?([.][0-9]+)?$")
    }
    if (b.match(numericNegExpr)) {
        return true
    } else {
        return false
    }
}

function isVietDate(b) {
    if (vietDateExpr == null) {
        vietDateExpr = new RegExp("^[0-3]?[0-9]/[0-1]?[0-9]/[0-9]{4}$")
    }
    if (b.match(vietDateExpr)) {
        return true
    } else {
        return false
    }
}

function isVietDateTime(b) {
    if (vietDateTimeExpr == null) {
        vietDateTimeExpr = new RegExp("^[0-3]?[0-9]/[0-1]?[0-9]/[0-9]{4} [0-2]?[0-9]:[0-5]?[0-9](:00)?$")
    }
    if (b.match(vietDateTimeExpr)) {
        return true
    } else {
        return false
    }
}

function isTime(b) {
    if (vietTimeExpr == null) {
        vietTimeExpr = new RegExp("^[0-2]?[0-9]:[0-5]?[0-9](:00)?$")
    }
    if (b.match(vietTimeExpr)) {
        return true
    } else {
        return false
    }
}

function isEmail(b) {
    if (emailExpr == null) {
        emailExpr = new RegExp("^[A-Za-z0-9](([_.-]?[a-zA-Z0-9]+)*)@([A-Za-z0-9]+)(([.-]?[a-zA-Z0-9]+)*).([A-Za-z]{2,})$")
    }
    if (b.match(emailExpr)) {
        return true
    } else {
        return false
    }
}

