                ajdia("editItem.aspx?tabindex=v_assets&" + queryDiff("tabindex") + "&id=" + a + "&noheader=on&childedit=on&followupjsfunc=" + escape("[JS]||location.reload||"), "assetparamsW", 1000, 560);
                return
        }
    }
    var b = "";
    if (a != -9) {
        b = "&id=" + a
    }
    location.href = "editItem.aspx?" + queryDiff("id") + b
}

